# Copy this to config.env and fill in the SSH details.
# config.env is gitignored — never commit real hostnames or usernames.
#
# Required:
REMOTE_SSH_HOST=

# Optional. Leave empty if REMOTE_SSH_HOST is an ssh_config alias whose
# `User` directive already specifies the remote login (recommended).
# Only set this if you want to force user@host on the SSH command line.
REMOTE_SSH_USER=

# Optional (defaults shown):
# NOTE: single-quote $HOME so it's expanded on the REMOTE shell, not locally.
# Canonical layout: $HOME/git/<repo>. Standardised across CF test boxes.
REMOTE_PROJECT_DIR='$HOME/git/cf-token-metadata-registry'
BRANCH="develop"
# HTTPS is the default — public repo, no auth needed on the remote box.
# If you want SSH, change to git@github.com:... and make sure the remote
# has a registered deploy key or SSH agent forwarding (ForwardAgent yes).
GIT_REPO_URL="https://github.com/cardano-foundation/cf-token-metadata-registry.git"

# Which env file the remote docker compose should use.
# .env         -> mainnet (genesis sync from slot 65836843)
# .env.preprod -> preprod (genesis sync from slot 0)
ENV_FILE=".env"

# Local ports the SSH tunnel will bind. The remote always exposes
# the API on 8080 and Postgres on 5432 (per docker-compose.yml + .env).
LOCAL_API_PORT="8080"
LOCAL_DB_PORT="5432"
